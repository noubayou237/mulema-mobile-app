# Database Connection
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?sslmode=require"

# JWT
JWT_SECRET="your_jwt_secret_here_at_least_32_chars"
JWT_EXPIRES_IN="7d"

# Email (Resend — https://resend.com)
# Create a free account, get an API key from the dashboard, set it here.
# RESEND_FROM is optional: defaults to onboarding@resend.dev (testing only).
# For production, add a verified domain in Resend and set: "Mulema App <noreply@yourdomain.com>"
RESEND_API_KEY="re_your_api_key_here"
RESEND_FROM="Mulema App <onboarding@resend.dev>"

# Storage (Cloudflare R2)
# Set USE_R2=true to enable R2 storage, false for local disk storage
USE_R2=true
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_REGION="auto"
R2_BUCKET_NAME="your-bucket-name"
R2_PUBLIC_URL="https://your-public-bucket-url.r2.dev"
