# API Configuration
# Update with your local machine's IP for physical device testing
EXPO_PUBLIC_API_IP=192.168.1.100

# Google OAuth
EXPO_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID="your-google-ios-client-id"
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID="your-google-android-client-id"

# Facebook OAuth
EXPO_PUBLIC_FACEBOOK_APP_ID="your-facebook-app-id"

# Expo Configuration
EXPO_PUBLIC_EXPO_USERNAME="your-expo-username"
EXPO_PUBLIC_APP_SLUG="mulema"
